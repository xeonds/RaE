{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "RaE",
  "scopeName": "source.rae",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#at-functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.rae",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.rae",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.rae",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.rae",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.rae",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.rae",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.rae",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rae",
          "match": "\\b(?i:file|struct|enum|bitfield|template|variant|let|in)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.rae",
          "match": "\\b(?i:i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|string|bytes|array)\\b"
        },
        {
          "name": "support.type.rae",
          "match": "\\b(?i:le|be)\\b"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "storage.modifier.rae",
          "match": "\\b(?i:after|align|count|validate|endian)\\b"
        }
      ]
    },
    "at-functions": {
      "patterns": [
        {
          "name": "support.function.rae",
          "match": "@(each|checksum|echo|write|block|select|align|object)\\b"
        },
        {
          "name": "keyword.operator.rae",
          "match": "@"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.rae",
          "match": "==|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.rae",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.rae",
          "match": "=>"
        },
        {
          "name": "keyword.operator.arithmetic.rae",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.logical.rae",
          "match": "!"
        },
        {
          "name": "keyword.operator.pipe.rae",
          "match": "\\|"
        },
        {
          "name": "punctuation.separator.rae",
          "match": "[.:;,]"
        },
        {
          "name": "punctuation.bracket.rae",
          "match": "[{}\\[\\]()]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.rae",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
